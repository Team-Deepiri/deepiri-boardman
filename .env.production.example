# Boardman production cloud env.
# Copy to `.env` on the VPS and fill values there. Do not commit real secrets.
#
# Production cloud must not run local Ollama/model inference. Use
# docker-compose.prod.yml and keep LLM_PROVIDER on a hosted provider when LLM
# features are required. Leave LLM-dependent features disabled for the first
# webhook/Plaky smoke if no provider key is approved yet.

PLAKY_API_KEY=your_rotated_plaky_api_key_here
GITHUB_PAT=your_rotated_github_service_pat_here
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret_here
WORKER_INTERNAL_SECRET=your_random_internal_worker_secret_here
ROUTE_SECRET=your_random_cloudflare_route_secret_here
BOARDMAN_SECRETS_ROTATED=false

# Deployment decisions to confirm before go-live.
BOARDMAN_TARGET_ENV=
GITHUB_AUTH_MODE=pat
BOARDMAN_PUBLIC_URL=https://boardman.example.com
GITHUB_WEBHOOK_EVENTS=issues,pull_request,pull_request_review,pull_request_review_comment,issue_comment

GITHUB_ORG=deepiri-org
GITHUB_SUPPORT_TEAM=Team-Deepiri/support-team
PLAKY_API_BASE=https://api.plaky.com/v1/public
PLAKY_PR_MERGE_STATUS=in_review
DATABASE_URL=sqlite+aiosqlite:///./boardman.db
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8090
LOG_LEVEL=INFO
CORS_ORIGINS=https://boardman.example.com

# Hosted LLM only. Do not set LLM_PROVIDER=ollama in production cloud.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PR_LINKING_LLM_ENABLED=false
ASSIGNMENT_IDENTITY_LLM_ENABLED=false

# Optional API-side cache only. Leave empty unless Redis is enabled explicitly.
AGENT_REDIS_URL=
AGENT_LANGCHAIN_TOOLS=true
