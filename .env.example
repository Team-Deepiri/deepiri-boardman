# =============================================================================
# REQUIRED — set these for normal Plaky ↔ GitHub operation
# =============================================================================
#
# Docker: copy this file to `.env` in the repo root. `docker compose` loads it via `env_file`
# (do not bake `.env` into the image — it is in `.dockerignore`). Avoid duplicating secrets in
# compose `environment: KEY=${KEY}`; an empty interpolation can override `env_file` and clear the key.

# [REQUIRED] Plaky API (tasks, comments, CLI list/create)
PLAKY_API_KEY=your_plaky_api_key_here

# [REQUIRED] GitHub REST API: org repo discovery, scan, DIRECTION init, agent tools
GITHUB_PAT=your_github_personal_access_token_here

# [REQUIRED] Must match the secret on the GitHub webhook. Empty = signature check
# disabled (local dev only; do not use in production)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
# Webhook should subscribe to: Issues, Pull requests, Pull request reviews, Issue comments


# =============================================================================
# OPTIONAL — defaults are fine unless you need to override
# =============================================================================

# --- Plaky ---
# Official public API base (X-API-Key auth). Old /v2 + Bearer was wrong for Plaky’s docs.
PLAKY_API_BASE=https://api.plaky.com/v1/public
PLAKY_PR_MERGE_STATUS=in_review
# When true, merge webhook sets PLAKY_PR_MERGE_STATUS only after every linked PR is merged or closed.
PLAKY_COMPLETE_WHEN_ALL_PRS_MERGED=true
# QA automation (must match your Plaky status keys). Empty = skip that transition.
# PLAKY_PR_NEEDS_QA_STATUS=needs_qa
# PLAKY_PR_IN_QA_STATUS=in_qa
# PLAKY_PR_QA_APPROVED_STATUS=qa_approved
# PLAKY_PR_QA_REJECTED_STATUS=qa_rejected
# PLAKY_SKIP_NEEDS_QA_FOR_DRAFT=true
# After Plaky status updates, enqueue arq job `plaky_reorder_group_job` (needs REDIS_URL + worker).
# PLAKY_REORDER_AFTER_STATUS_CHANGE=false
# Comma-separated substrings for “done” detection when reordering items in a group.
# PLAKY_REORDER_DONE_STATUS_MARKERS=done,complete,closed,resolved,archive,shipped,merged
# Blend word-bag cosine into PR↔task fuzzy score (0 = legacy SequenceMatcher only).
# PR_LINKING_COSINE_WEIGHT=0.35
# Default placement for new items (API: board + group; "table" in UI = group)
# Or resolve by name: GET /api/v1/plaky/boards/match?query=Your+Board+Name
# PLAKY_DEFAULT_BOARD_ID=
# PLAKY_DEFAULT_GROUP_ID=

# --- GitHub ---
# Org for API repo listing and routing (default: deepiri-org)
GITHUB_ORG=deepiri-org
# Roster for names/logins: GET /api/v1/github/support-team/members (PAT needs read:org to see the team)
# GITHUB_SUPPORT_TEAM=Team-Deepiri/support-team
# GITHUB_SKIP_ARCHIVED=true
# Scan GET /orgs/{org}/teams for slug/name patterns (qa-tier-3, t2-qa, "Tier 2 …"). Members get that qa_tier.
# If no teams match, Phase 1 uses decayed PR activity only. Token needs read:org.
# GITHUB_QA_TIER_TEAM_SCAN_ENABLED=true
# GITHUB_QA_ACTIVITY_HALF_LIFE_DAYS=180
# GITHUB_QA_ACTIVITY_SEARCH_MAX_PAGES=5
# GITHUB_QA_ACTIVITY_TIER3_MIN_DISTINCT_T3_REPOS=2
# GITHUB_QA_ACTIVITY_TIER3_MIN_WEIGHTED_SCORE=5
# GITHUB_QA_ACTIVITY_TIER2_MIN_DISTINCT_T2PLUS_REPOS=3
# GITHUB_QA_ACTIVITY_TIER2_MIN_WEIGHTED_SCORE=2.5
# DEFAULT_REPO_CATEGORY=
# DEFAULT_PLAKY_TABLE=

# --- Service & database ---
DATABASE_URL=sqlite+aiosqlite:///./boardman.db
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8090
LOG_LEVEL=INFO

# --- Repo routing (see repos.yml) ---
# REPOS_YML_PATH=repos.yml
# TEAM_ASSIGNMENTS_YML_PATH=team_assignments.yml
# Bearer secret for POST /api/v1/assignment/pick-qa (Cloudflare Worker or cron). Empty = route disabled.
# WORKER_INTERNAL_SECRET=

# --- PR ↔ Plaky fuzzy linking (pull_request.opened when body has no Fixes/Closes #issue) ---
# On by default. Set PR_LINKING_PIPELINE_ENABLED=false to disable. Uses DB + optional board scan,
# score bands, optional LLM rerank (PR_LINKING_LLM_ENABLED=true).
# PR_LINKING_PIPELINE_ENABLED=true
# PR_LINKING_FETCH_BOARD_ITEMS=true
# PR_LINKING_MAX_BOARD_ITEMS_SCAN=200
# PR_LINKING_BOARD_MAX_PAGES=10
# PR_LINKING_HIGH_THRESHOLD=90
# PR_LINKING_MEDIUM_THRESHOLD=50
# PR_LINKING_TOP_N_FOR_LLM=5
# PR_LINKING_LLM_ENABLED=false
# PR_LINKING_LLM_MIN_CONFIDENCE=0.75

# --- Redis (arq agent queue + optional distributed rate limits) ---
# Docker Compose sets REDIS_URL=redis://redis:6379/0 for API + boardman-worker.
# REDIS_URL=redis://localhost:6379/0
# POST /api/v1/agent/chat with "queue": true enqueues; poll GET /api/v1/agent/jobs/{job_id}
# AGENT_ASYNC_ENQUEUE_ENABLED=true
# Leaky-bucket on /agent/chat and /agent/scan (per client IP):
# AGENT_RATE_LIMIT_ENABLED=true
# AGENT_RATE_LIMIT_CAPACITY=16
# AGENT_RATE_LIMIT_LEAK_PER_SECOND=0.5
# AGENT_RATE_LIMIT_USE_REDIS=false

# Plaky board schema cache for faster agent turns (seconds; 0 = off)
# PLAKY_BOARD_SCHEMA_CACHE_TTL_SECONDS=90

# --- LLM ---
# Ollama: leave LLM_MODEL unset to auto-pick from GET /api/tags (qwen > llama > …). Optional override:
# LLM_MODEL=qwen2.5:7b
# LLM_PROVIDER=ollama
# Host / poetry: localhost. Docker Compose pins boardman to http://ollama:11434 (this value is ignored there).
OLLAMA_BASE_URL=http://localhost:11434
# Keep model loaded between requests (reduces cold-start latency). Empty = Ollama default.
OLLAMA_KEEP_ALIVE=30m
# Optional max new tokens per completion (plain chat + LangChain). Lower = faster; unset = Ollama default.
# OLLAMA_NUM_PREDICT=512
# Plain chat UI uses POST /api/v1/agent/chat/stream (SSE) for snappier perceived latency — no token cap required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Agent ---
AGENT_MAX_HISTORY=50
AGENT_REQUIRE_CONFIRM_BULK=true
PROMPT_VERSION=2026-04-09
AGENT_LANGCHAIN_TOOLS=true
# Max LangGraph steps when multi-step tools are used (POST body use_tools: true or UI toggle).
AGENT_RECURSION_LIMIT=22
# Fast path: POST /api/v1/agent/chat omits use_tools or sends false → one LLM call. Send use_tools: true
# (or enable “Multi-step agent” in boardman-ui) when you need the tool loop.
# Verbose LangChain step traces (dev only; very noisy)
# AGENT_LANGCHAIN_VERBOSE=false
# Local without Docker: UVICORN_RELOAD=1 poetry run python -m boardman.main

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:5176,http://127.0.0.1:5176,http://localhost:8088,http://127.0.0.1:8088
