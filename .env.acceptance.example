# Boardman acceptance-only env (engineering completion).
# This file is intentionally fake and contains no production secrets.
# It is for offline acceptance validation, not live deployment.

PLAKY_API_KEY=acc_fake_plaky_key_not_real
GITHUB_PAT=acc_fake_github_pat_not_real
GITHUB_WEBHOOK_SECRET=acc_fake_webhook_secret_not_real
WORKER_INTERNAL_SECRET=acc_fake_worker_secret_not_real
ROUTE_SECRET=acc_fake_route_secret_not_real
BOARDMAN_SECRETS_ROTATED=true

# Acceptance decisions
BOARDMAN_TARGET_ENV=acceptance-local
GITHUB_AUTH_MODE=pat
BOARDMAN_PUBLIC_URL=https://acceptance.local
GITHUB_WEBHOOK_EVENTS=issues,pull_request,pull_request_review,pull_request_review_comment,issue_comment

GITHUB_ORG=deepiri-org
GITHUB_SUPPORT_TEAM=Team-Deepiri/support-team
PLAKY_API_BASE=https://api.plaky.com/v1/public
PLAKY_PR_MERGE_STATUS=in_review
DATABASE_URL=sqlite+aiosqlite:///./boardman.acceptance.db
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8090
LOG_LEVEL=INFO
CORS_ORIGINS=https://acceptance.local

# Hosted-LLM mode only; no local Ollama inference in wave-one production behavior.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PR_LINKING_LLM_ENABLED=false
ASSIGNMENT_IDENTITY_LLM_ENABLED=false

# Optional cache left disabled in acceptance.
AGENT_REDIS_URL=
AGENT_LANGCHAIN_TOOLS=true
